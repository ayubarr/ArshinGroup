/*
/*
  # Аршин Групп - Полная схема базы данных

  ## Новые таблицы:

  1. `site_settings` - Настройки сайта (логотип, телефон, адрес, email)
  2. `navigation_menus` - Разделы основного меню верхнего уровня
  3. `navigation_items` - Элементы подменю (привязаны к разделам меню)
  4. `banners` - Баннеры/слайдеры на главной странице
  5. `services` - Каталог услуг компании
  6. `service_categories` - Категории услуг
  7. `products` - Каталог продуктов/оборудования
  8. `product_categories` - Категории продуктов
  9. `news` - Новости и статьи
  10. `contacts` - Контактная информация (офисы)
  11. `admin_users` - Администраторы панели управления

  ## Безопасность:
  - RLS включен для всех таблиц
  - Публичный доступ на чтение для контентных таблиц
  - Запись только для авторизованных администраторов
*/

-- ============================================================
-- SITE SETTINGS
-- ============================================================
CREATE TABLE IF NOT EXISTS site_settings (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  key text UNIQUE NOT NULL,
  value text,
  value_json jsonb,
  description text,
  updated_at timestamptz DEFAULT now()
);

ALTER TABLE site_settings ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Anyone can read site settings"
  ON site_settings FOR SELECT
  TO anon, authenticated
  USING (true);

CREATE POLICY "Authenticated users can update site settings"
  ON site_settings FOR UPDATE
  TO authenticated
  USING (true)
  WITH CHECK (true);

CREATE POLICY "Authenticated users can insert site settings"
  ON site_settings FOR INSERT
  TO authenticated
  WITH CHECK (true);

-- ============================================================
-- NAVIGATION MENUS (верхний уровень)
-- ============================================================
CREATE TABLE IF NOT EXISTS navigation_menus (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  title_ru text NOT NULL,
  title_en text DEFAULT '',
  title_zh text DEFAULT '',
  slug text UNIQUE NOT NULL,
  sort_order integer DEFAULT 0,
  is_active boolean DEFAULT true,
  created_at timestamptz DEFAULT now(),
  updated_at timestamptz DEFAULT now()
);

ALTER TABLE navigation_menus ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Anyone can read navigation menus"
  ON navigation_menus FOR SELECT
  TO anon, authenticated
  USING (is_active = true);

CREATE POLICY "Authenticated users can manage navigation menus"
  ON navigation_menus FOR INSERT
  TO authenticated
  WITH CHECK (true);

CREATE POLICY "Authenticated users can update navigation menus"
  ON navigation_menus FOR UPDATE
  TO authenticated
  USING (true)
  WITH CHECK (true);

CREATE POLICY "Authenticated users can delete navigation menus"
  ON navigation_menus FOR DELETE
  TO authenticated
  USING (true);

-- ============================================================
-- NAVIGATION ITEMS (подменю - группы и ссылки)
-- ============================================================
CREATE TABLE IF NOT EXISTS navigation_items (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  menu_id uuid REFERENCES navigation_menus(id) ON DELETE CASCADE,
  parent_id uuid REFERENCES navigation_items(id) ON DELETE CASCADE,
  title_ru text NOT NULL,
  title_en text DEFAULT '',
  title_zh text DEFAULT '',
  url text DEFAULT '',
  sort_order integer DEFAULT 0,
  is_active boolean DEFAULT true,
  level integer DEFAULT 1,
  created_at timestamptz DEFAULT now(),
  updated_at timestamptz DEFAULT now()
);

ALTER TABLE navigation_items ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Anyone can read navigation items"
  ON navigation_items FOR SELECT
  TO anon, authenticated
  USING (is_active = true);

CREATE POLICY "Authenticated users can manage navigation items"
  ON navigation_items FOR INSERT
  TO authenticated
  WITH CHECK (true);

CREATE POLICY "Authenticated users can update navigation items"
  ON navigation_items FOR UPDATE
  TO authenticated
  USING (true)
  WITH CHECK (true);

CREATE POLICY "Authenticated users can delete navigation items"
  ON navigation_items FOR DELETE
  TO authenticated
  USING (true);

-- ============================================================
-- BANNERS
-- ============================================================
CREATE TABLE IF NOT EXISTS banners (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  title_ru text NOT NULL,
  title_en text DEFAULT '',
  title_zh text DEFAULT '',
  subtitle_ru text DEFAULT '',
  subtitle_en text DEFAULT '',
  subtitle_zh text DEFAULT '',
  image_url text DEFAULT '',
  button_text_ru text DEFAULT '',
  button_text_en text DEFAULT '',
  button_text_zh text DEFAULT '',
  button_url text DEFAULT '',
  sort_order integer DEFAULT 0,
  is_active boolean DEFAULT true,
  created_at timestamptz DEFAULT now(),
  updated_at timestamptz DEFAULT now()
);

ALTER TABLE banners ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Anyone can read active banners"
  ON banners FOR SELECT
  TO anon, authenticated
  USING (is_active = true);

CREATE POLICY "Authenticated users can manage banners"
  ON banners FOR INSERT
  TO authenticated
  WITH CHECK (true);

CREATE POLICY "Authenticated users can update banners"
  ON banners FOR UPDATE
  TO authenticated
  USING (true)
  WITH CHECK (true);

CREATE POLICY "Authenticated users can delete banners"
  ON banners FOR DELETE
  TO authenticated
  USING (true);

